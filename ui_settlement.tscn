[gd_scene load_steps=2 format=3 uid="uid://bcik5qdd1gx1u"]

[sub_resource type="GDScript" id="GDScript_bpnin"]
script/source = "extends Control

@export var name_text : Label
@export var bar_text : Label
@export var value_text : RichTextLabel

var name_str : String
var value_str : String

const bar_str = \"..................................................................\"

func _ready() -> void:
	name_text.text = name_str
	value_text.text = value_str
	
	var tween = get_tree().create_tween()
	tween.tween_method(func(t):
		bar_text.text = bar_str.substr(0, int(bar_str.length() * t))
	, 0.0, 1.0, 0.2)
	tween.tween_callback(func():
		value_text.show()
	)
"

[node name="HBoxContainer" type="HBoxContainer" node_paths=PackedStringArray("name_text", "bar_text", "value_text")]
script = SubResource("GDScript_bpnin")
name_text = NodePath("Label")
bar_text = NodePath("Label2")
value_text = NodePath("Label3")

[node name="Label" type="Label" parent="."]
layout_mode = 2

[node name="Label2" type="Label" parent="."]
layout_mode = 2
size_flags_horizontal = 3
clip_text = true

[node name="Label3" type="RichTextLabel" parent="."]
visible = false
layout_mode = 2
bbcode_enabled = true
fit_content = true
autowrap_mode = 0
